# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage files.
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials.
/config/master.key

# Ignore assets.
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Docker
.kamal/

# GitHub
.github/

# Node
node_modules/
